root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Code files → 4 spaces, 120 cols to match Prettier
[*.{js,jsx,mjs,cjs,ts,tsx,mts,cts,vue,html,css,scss,sass,less,styl,json}]
indent_style = space
indent_size = 4
max_line_length = 120

# YAML/TOML → keep 2 spaces
[*.{yml,yaml,toml}]
indent_style = space
indent_size = 2

# Markdown → don’t trim hard-break spaces
[*.md]
trim_trailing_whitespace = false
max_line_length = off